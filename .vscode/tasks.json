{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build with Vite",
      "type": "shell",
      "command": "node",
      "args": [
        "${workspaceFolder}/node_modules/vite/bin/vite.js",
        "build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Dev Server (Vite)",
      "type": "shell",
      "command": "node",
      "args": [
        "${workspaceFolder}/node_modules/vite/bin/vite.js",
        "--port",
        "3000",
        "--host",
        "0.0.0.0"
      ],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^ready in",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      }
    }
  ]
}
